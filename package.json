{
  "name": "Joanium",
  "version": "0.1.0",
  "description": "Your AI assistant.",
  "type": "module",
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint ."
  },
  "keywords": [
    "Joanium",
    "automation",
    "integration",
    "AI",
    "Agent",
    "AI-Agent",
    "Assistant",
    "chatbot",
    "AI-Chatbot",
    "bot",
    "AI-Bot",
    "Agentic-AI",
    "Agentic-AI-Assistant",
    "Agentic-AI-Chatbot",
    "Agentic-AI-Bot",
    "Agentic-AI-Agent"
  ],
  "author": "Joel Jolly",
  "license": "MIT",
  "dependencies": {
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.11.0"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.2",
    "eslint": "^10.1.0"
  },
  "build": {
    "appId": "com.Joanium.app",
    "productName": "Joanium",
    "directories": {
      "output": "dist"
    },
    "files": [
      "App.js",
      "Packages/**/*",
      "Public/**/*",
      "Icons/Logo.ico",
      "Icons/Logo.icns",
      "Icons/Logo.png"
    ],
    "extraResources": [
      {
        "from": "Data/Models.json",
        "to": "Data/Models.json"
      }
    ],
    "win": {
      "icon": "Icons/Logo.ico"
    },
    "mac": {
      "icon": "Icons/Logo.icns"
    },
    "linux": {
      "icon": "Icons/Logo.png"
    }
  }
}