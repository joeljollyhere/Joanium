{
  "name": "Joanium",
  "version": "2026.411.0",
  "description": "Your AI assistant.",
  "type": "module",
  "workspaces": [
    "Core/Electron",
    "Packages/*",
    "Packages/Capabilities/*",
    "Packages/Features/*"
  ],
  "imports": {
    "#capabilities/*": "./Packages/Capabilities/*",
    "#core/*": "./Core/*",
    "#features/*": "./Packages/Features/*",
    "#main/*": "./Packages/Main/*",
    "#modals/*": "./Packages/Modals/*",
    "#pages/*": "./Packages/Pages/*",
    "#renderer/*": "./Packages/Renderer/*",
    "#system/*": "./Packages/System/*"
  },
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "version:date": "node ./Scripts/SetVersionByDate.mjs",
    "build": "node ./Scripts/Build.mjs",
    "minify:dry": "node ./Scripts/Minify.mjs --dry",
    "lint": "eslint .",
    "packages:audit": "node ./Scripts/AuditWorkspacePackages.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "Joanium",
    "Joana",
    "automation",
    "integration",
    "AI",
    "Agent",
    "AI-Agent",
    "Assistant",
    "chatbot",
    "AI-Chatbot",
    "bot",
    "AI-Bot",
    "Agentic-AI",
    "Agentic-AI-Assistant",
    "Agentic-AI-Chatbot",
    "Agentic-AI-Bot",
    "Agentic-AI-Agent"
  ],
  "author": "Joel Jolly",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-log": "5.4.3",
    "electron-updater": "6.8.3",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "clean-css": "5.3.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.2",
    "eslint": "10.2.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "html-minifier-terser": "7.2.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2",
    "terser": "5.46.1",
    "vite": "8.0.8",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6"
  }
}
