{
  "name": "Evelina",
  "version": "0.1.0",
  "description": "Your AI assistant.",
  "type": "module",
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint ."
  },
  "keywords": [
    "Evelina",
    "electron",
    "automation",
    "integration",
    "AI",
    "Agent",
    "AI-Agent",
    "Assistant"
  ],
  "author": "Joel Jolly",
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0"
  },
  "build": {
    "appId": "com.Evelina.app",
    "productName": "Evelina",
    "directories": {
      "output": "dist"
    },
    "files": [
      "App.js",
      "Packages/**/*",
      "Public/**/*",
      "Data/**/*"
    ],
    "win": {
      "icon": "Icons/Logo.ico"
    },
    "mac": {
      "icon": "Icons/Logo.icns"
    },
    "linux": {
      "icon": "Icons/Logo.png"
    }
  }
}
