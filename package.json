{
  "name": "openworld",
  "version": "0.1.0",
  "description": "An Electron app that connects and controls your world",
  "type": "module",
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint src/"
  },
  "keywords": ["electron", "automation", "integration"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.0.2"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3"
  },
  "build": {
    "appId": "com.openworld.app",
    "productName": "openworld",
    "directories": {
      "output": "dist"
    },
    "files": [
      "App.js",
      "Packages/**/*",
      "Public/**/*",
      "Data/**/*"
    ]
  }
}
