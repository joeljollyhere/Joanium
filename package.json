{
  "name": "openworld",
  "version": "0.1.0",
  "description": "An Electron app that connects and controls your world",
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "electron",
    "automation",
    "integration"
  ],
  "author": "Joel Jolly",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3"
  },
  "build": {
    "appId": "com.openworld.app",
    "productName": "openworld",
    "asar": true,
    "compression": "maximum",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "App.js",
      "Packages/**/*",
      "Public/**/*",
      "Data/**/*"
    ],
    "win": {
      "target": "nsis",
      "sign": null,
      "signingHashAlgorithms": null
    }
  }
}