{
  "name": "Joanium",
  "version": "0.1.0",
  "description": "Your AI assistant.",
  "type": "module",
  "workspaces": [
    "Core/Electron",
    "Packages/*",
    "Packages/Features/*"
  ],
  "imports": {
    "#capabilities/*": "./Packages/Capabilities/*",
    "#core/*": "./Core/*",
    "#features/*": "./Packages/Features/*",
    "#main/*": "./Packages/Main/*",
    "#modals/*": "./Packages/Modals/*",
    "#pages/*": "./Packages/Pages/*",
    "#renderer/*": "./Packages/Renderer/*",
    "#system/*": "./Packages/System/*"
  },
  "main": "App.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "keywords": [
    "Joanium",
    "Joana",
    "automation",
    "integration",
    "AI",
    "Agent",
    "AI-Agent",
    "Assistant",
    "chatbot",
    "AI-Chatbot",
    "bot",
    "AI-Bot",
    "Agentic-AI",
    "Agentic-AI-Assistant",
    "Agentic-AI-Chatbot",
    "Agentic-AI-Bot",
    "Agentic-AI-Agent"
  ],
  "author": "Joel Jolly",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.2",
    "eslint": "^10.1.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1"
  },
  "build": {
    "appId": "com.Joanium.app",
    "productName": "Joanium",
    "directories": {
      "output": "dist"
    },
    "files": [
      "App.js",
      "Core/**/*",
      "Packages/**/*",
      "Public/**/*",
      "Assets/**/*",
      "SystemInstructions/**/*"
    ],
    "extraResources": [
      {
        "from": "Config/Models.json",
        "to": "Config/Models.json"
      },
      {
        "from": "Config/WindowState.json",
        "to": "Config/WindowState.json"
      },
      {
        "from": "Skills",
        "to": "Skills"
      },
      {
        "from": "Personas",
        "to": "Personas"
      },
      {
        "from": "Instructions",
        "to": "Instructions"
      }
    ],
    "win": {
      "icon": "Assets/Logo/Logo.ico"
    },
    "mac": {
      "icon": "Assets/Logo/Logo.icns"
    },
    "linux": {
      "icon": "Assets/Logo/Logo.png"
    }
  }
}
